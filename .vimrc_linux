call plug#begin()

Plug 'nanotech/jellybeans.vim'
Plug 'morhetz/gruvbox'
Plug 'tpope/vim-eunuch'
Plug 'yegappan/mru'
Plug 'majutsushi/tagbar'
"Plug 'github/copilot.vim'
Plug 'mbbill/undotree'
Plug 'tpope/vim-surround'
Plug 'preservim/nerdtree'
Plug 'jiangmiao/auto-pairs'
Plug 'tpope/vim-repeat'
Plug 'junegunn/fzf', {'do': {-> fzf#install()}}
Plug 'junegunn/fzf.vim'
Plug 'tpope/vim-commentary'
Plug 'preservim/nerdcommenter'
Plug 'vim-airline/vim-airline'
Plug 'vim-airline/vim-airline-themes'
Plug 'tpope/vim-fugitive'
Plug 'vimwiki/vimwiki'
Plug 'frazrepo/vim-rainbow'
Plug 'vim-autoformat/vim-autoformat'
Plug 'machakann/vim-swap'
Plug 'vim-scripts/SyntaxAttr.vim'
Plug 'octol/vim-cpp-enhanced-highlight'
Plug 'skywind3000/asyncrun.vim'
"Plug 'puremourning/vimspector'
Plug 'vim-scripts/matrix.vim--Yang'
Plug 'drmikehenry/vim-fontsize'
" Plug 'habamax/vim-shout'
Plug 'junegunn/vim-easy-align'
Plug 'tpope/vim-unimpaired'
Plug 'bronson/vim-visual-star-search'
Plug 'tpope/vim-abolish'
Plug 'mbbill/desertEx'
Plug 'dikiaap/minimalist'

call plug#end()

set enc=utf-8
set nocompatible
source $VIMRUNTIME/vimrc_example.vim

set number
set relativenumber
set ignorecase
set smartcase
set mouse=a
set incsearch
set scrolloff=0
set nobackup
" set hidden
set completeopt-=preview

syntax on

" Enable true color 启用终端24位色
if exists('+termguicolors')
  let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
  let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
  set termguicolors
endif

if has('termguicolors')
  set termguicolors
  let &t_8u = "\<Esc>[58:2::%lu:%lu:%lum"
  if &term =~# 'xterm\|tmux\|screen\|kitty\|wezterm\|alacritty'
    let &t_RV = "\<Esc>[>c"
  endif
endif

" In tmux, force SGR mouse protocol so dragging events are reported correctly.
if &term =~# 'tmux\|screen'
  set ttymouse=sgr
endif


set cursorline

augroup MyGruvboxOverrides
  autocmd!
  autocmd ColorScheme gruvbox highlight YcmWarningSign ctermfg=214 ctermbg=237 guifg=#fabd2f guibg=#a68146
  autocmd ColorScheme gruvbox highlight YcmErrorSign ctermfg=167 ctermbg=237 guifg=#fb4934 guibg=#b04231
augroup END

augroup MyJellybensOverrides
  autocmd!
  autocmd ColorScheme jellybeans highlight SyntasticWarning cterm=undercurl gui=undercurl guisp=#fabd2f
  autocmd ColorScheme jellybeans highlight SyntasticError cterm=undercurl gui=undercurl guisp=#fb4934
  autocmd ColorScheme jellybeans highlight YcmWarningSign ctermfg=214 ctermbg=237 guifg=#fabd2f guibg=#a68146
  autocmd ColorScheme jellybeans highlight YcmErrorSign ctermfg=167 ctermbg=237 guifg=#fb4934 guibg=#b04231
augroup END

if has('gui_running')
  colorscheme desertEx
  " let g:airline_theme='base16_atelier_heath'
  let g:airline_theme='base16_atelier_plateau'
  highlight CursorLine term=underline ctermbg=237 guibg=gray20
  highlight Pmenu ctermfg=223 ctermbg=239 guifg=#ebdbb2 guibg=#504945
  highlight LineNr term=underline ctermfg=11 guifg=burlywood3 guibg=gray17
  highlight CursorLineNr term=bold cterm=underline ctermfg=11 gui=bold guifg=yellow guibg=gray20
  highlight NonText term=bold ctermfg=12 guifg=cyan guibg=gray17
  highlight SpellCap term=reverse ctermbg=12 gui=undercurl guisp=yellow
else
  " colorscheme gruvbox
  " let g:airline_theme='gruvbox'
  "------------------------
  colorscheme jellybeans
  let g:airline_theme='base16_atelier_heath'
endif

"packadd termdebug

set bg=dark

set guifont=Monospace\ 21

" Udowarning
let g:undofile_warn_mode=2

" Airline
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#show_tab_nr = 1
let g:airline#extensions#tabline#tab_nr_type = 1
let g:airline#extensions#tabline#show_splits = 0
let g:airline#extensions#tabline#show_buffers = 0
let g:airline#extensions#tabline#buffer_nr_show = 0
let g:airline_powerline_fonts = 1
let g:airline#extensions#tabline#formatter = 'unique_tail'
let g:airline#extensions#ycm#enabled = 1

let g:gruvbox_invert_tabline=1
let g:gruvbox_invert_signs = 1
let g:gruvbox_improved_warnings=1
" let g:gruvbox_improved_strings=1

let do_syntax_sel_menu = 1
let do_no_layload_menus = 1

" Tagbar
nnoremap <F10>      :TagbarToggle<CR>
inoremap <F10> <C-O>:TagbarToggle<CR>

nnoremap <C-Q> :q<CR>
nnoremap <leader>sv :source ~/.vimrc<CR>
nnoremap <silent> <C-L> :nohlsearch<CR><C-L>

" 开关撤销树的键映射
nnoremap <F2>      :UndotreeToggle<CR>
inoremap <F2> <C-O>:UndotreeToggle<CR>

tnoremap <Esc><Esc> <C-W>N
" tnoremap <C-A> <C-W>.

" F7: Step Over (executes function calls without entering them)
nnoremap <F7> :Over<CR>
" F6: Step Into (enters function calls)
nnoremap <F6> :Step<CR>
" F5 Add an breakpoint
nnoremap <F5> :Break<CR>

nnoremap <Leader>t :botright terminal ++rows=20<CR>
nnoremap <Leader>v :botright vs <bar> terminal ++curwin<CR>
" nnoremap <Leader>nt :tabe \| ter ++curwin<CR>
nnoremap <silent><Leader>nt :tab ter<CR>

" Mappings in terminal mode
tnoremap <C-S-V> <C-W>"+

noremap <leader>rb :RainbowToggle<CR>

nnoremap<F11> :cprevious<CR>
nnoremap<F12> :cnext<CR>

nnoremap<S-F11> :lprevious<CR>
nnoremap<S-F12> :lnext<CR>

noremap <MiddleMouse> :tabclose<CR>

" switch among the tabs
nnoremap<C-Tab> gt
nnoremap<C-S-Tab> gT

" nnoremap <F3> :Autoformat<CR>
" xnoremap <F3> :Autoformat<CR>
" nnoremap <silent><Space> :AutoformatLine<CR>

nnoremap <Leader>a      :call SyntaxAttr()<CR>

" Avoid to insert `;2u` int terminal mode when pressing Shift+Space
tnoremap <S-Space> <Space>

" Indent settings
au FileType c,cpp,objc,sql  setlocal expandtab shiftwidth=4 softtabstop=4 tabstop=4 cinoptions=:0,g0,(0,w1
au FileType json            setlocal expandtab shiftwidth=2 softtabstop=2
au FileType vim             setlocal expandtab shiftwidth=2 softtabstop=2
au FileType sh              setlocal expandtab shiftwidth=4 softtabstop=4 tabstop=4
au FileType go              setlocal noexpandtab tabstop=4 shiftwidth=4 softtabstop=4

if v:version >= 800
  packadd! editexisting
endif

if exists('$VIM_TERMINAL')
  echoerr 'Do not run Vim inside a Vim terminal'
  quit
endif

if has('persistent_undo')
  set undofile

  if has('win32')
    set undodir=$HOME/vimfiles/undodir
  else
    set undodir=~/.vim/undodir
  endif

  if !isdirectory(&undodir)
    call mkdir(&undodir, 'p', 0700)
  endif
endif

source $VIMRUNTIME/ftplugin/man.vim
set keywordprg=:Man

" Copy and paste with system clipboard
if has('gui_running')
  nnoremap <C-S-V> "+gP
  inoremap <C-S-V> <C-O>"+gp
  vnoremap <C-S-C> "+y
  cnoremap <C-S-V> <C-r>+
  "tnoremap <Esc><Esc> <C-\><C-n>
else
  nnoremap <C-V> <C-V>
endif

set tags=./tags;,tags,/usr/local/etc/systags

augroup TermdebugResize
  " Clear any old autocommands in this group to prevent duplicates
  autocmd!
  " When a file of type 'gdb' is opened (like Termdebug's GDB window)
  " set its width to 45 columns.
  autocmd FileType termdebug vertical resize 46 | resize 10
augroup END

" Set fold method
set foldmethod=syntax
set foldlevelstart=99

"Close gvim menubar and toolbar, set font in gvim
if has('gui_running')
  set guioptions-=m
  set guioptions-=T
  set guioptions-=r
endif

let g:autoformat_verbosemode=1

let &t_Cs = "\e[4:3m" " Start undercurl
let &t_Ce = "\e[4:0m" " End underline/undercurl
" let &t_8u = "\<Esc>[58:2::%lu:%lu:%lum"
let g:terminal_ansi_colors = [
      \'#282828', '#CC241D', '#98971A', '#D79921',
      \'#458588', '#B16286', '#689D6A', '#D65D0E',
      \'#fb4934', '#b8bb26', '#fabd2f', '#83a598',
      \'#d3869b', '#8ec07c', '#fe8019', '#FBF1C7' ]

highlight Terminal guibg='#282828'
highlight Terminal guifg='#ebdbb2'

let g:asyncrun_open = 15

command! -bang -range -nargs=* -complete=file Make AsyncRun -program=make @<args>
nnoremap<silent><F8> :if g:asyncrun_status != 'running'<bar>
      \if &modifiable<bar>
        \update<bar>
      \endif<bar>
        \exec 'Make'<bar>
      \else<bar>
        \AsyncStop<bar>
      \endif<CR>
nnoremap<S-F8> :cclose<CR>

" NerdTree
nnoremap <F9> :NERDTreeToggle<CR>
inoremap <F9> <C-O>:NERDTreeToggle<CR>
" Exit Vim if NERDTree is the only window remaining in the only tab.
autocmd BufEnter * if tabpagenr('$') == 1 && winnr('$') == 1 && exists('b:NERDTree') && b:NERDTree.isTabTree() | call feedkeys(":quit\<CR>:\<BS>") | endif

" Adjust the size of the window
if has('gui_running')
  nnoremap <C-=> <C-W>+
  nnoremap <C-_> <C-W>-
  nnoremap <C-.> <C-W>>
  nnoremap <C-,> <C-W><
endif

" Vimwiki
let g:vimwiki_list = [{'path': '~/vimwiki/',
      \ 'syntax': 'markdown', 'ext': 'md'}]

augroup TermNoNumber
  autocmd!
  autocmd BufWinEnter * if &buftype ==# 'terminal' | setlocal nonumber | setlocal nonu norelativenumber | endif
augroup END

" YCM config
source /home/zomjie/.vim/pack/my/start/lsp-examples/vimrc.generated
let g:ycm_autoclose_preview_window_after_insertion = 1
let g:ycm_autoclose_preview_window_after_completion = 1
let g:ycm_complete_in_comments = 1
let g:ycm_key_invoke_completion = '<C-Z>'
let g:ycm_auto_trigger = 1
let g:ycm_always_populate_location_list = 1

"let g:ycm_min_num_identifier_candidate_chars = 1
let g:ycm_clangd_uses_ycmd_caching = 0

let g:ycm_complete_in_strings = 1

" When the cursor hover on a type
let g:ycm_auto_hover=''
nmap <leader>dt <plug>(YCMHover)

nnoremap <Leader>fi :YcmCompleter FixIt<CR>
nnoremap <Leader>gt :YcmCompleter GoTo<CR>
nnoremap <Leader>gd :tab YcmCompleter GoToDefinition<CR>
nnoremap <Leader>gh :YcmCompleter GoToDeclaration<CR>
nnoremap <Leader>gr :YcmCompleter GoToReferences<CR>
nnoremap <Leader>rr :YcmCompleter RefactorRename<SPACE>
nnoremap <Leader>do :YcmCompleter GetDoc<CR>
nnoremap <Leader>sd :YcmShowDetailedDiagnostic<CR>
nnoremap <F3> :YcmCompleter Format<CR>
xnoremap <F3> :YcmCompleter Format<CR>

" " 自动检测终端的“括号粘贴”序列
" if &term =~ 'xterm\|screen\|tmux'
"     let &t_SI = "\<Esc>[?2004h"
"     let &t_EI = "\<Esc>[?2004l"
"     set t_BE=
"     exec "set <PasteStart>=\<Esc>[200~"
"     exec "set <PasteEnd>=\<Esc>[201~"
"     set pastetoggle=<PasteStart>
" endif

au FileType yaml setlocal
          \ expandtab      " 敲 Tab 实际插入空格
          \ tabstop=2      " Tab 显示宽度 2
          \ shiftwidth=2   " 自动缩进每次 2 空格
          \ softtabstop=2  " 退格/删除按 2 空格粒度
          \ autoindent     " 新行继承上一行缩进
          \ smartindent    " 智能缩进
nnoremap <C-V> <C-V>

" Disable Background Color Erase (BCE)
if &term =~ '256color' || &term =~ 'truecolor'
  set t_ut=
endif

" LSP examples
" source /home/zhangsj/local/lsp-examples/vimrc.generated

if executable('zsh')
   set shell=zsh
endif

" Disable line numbers in terminal buffers
autocmd TerminalWinOpen * setlocal nonumber norelativenumber

" function! ExeShellCmd()
"   let l:curr_cmd = input('Enter a command: ', '', 'shellcmd')
"   if !empty(l:curr_cmd)
"     let g:last_cmd = l:curr_cmd
"     execute 'Sh ' . l:curr_cmd
"   elseif exists("g:last_cmd")
"     execute 'Sh ' . g:last_cmd
"   endif
" endfunction

" nnoremap <Leader>sl :call ExeShellCmd()<CR>

nnoremap <Leader>sl :execute 'Sh '. expand(&makeprg)<CR>

" nnoremap <Leader>sl :execute 'Sh ' expand(&makeprg)<CR>

function! JumpAndReturn()
  " 保存当前窗口编号
  let l:current_win = winnr()
  " 执行正常的跳转
  execute "normal! \<CR>"
  " 返回原窗口 - 使用 l: 前缀确保是局部变量
  execute l:current_win . "wincmd w"
endfunction
autocmd FileType qf nnoremap <buffer> p :call JumpAndReturn()<CR>

" nnoremap <Enter> <C-W>gf
"
nnoremap <Leader>as :AsyncStop<CR>
" command! -bang -range -nargs=* AR <line1>,<line2>AsyncRun @<args>
nnoremap <Leader>ar :execute "'<,'>AsyncRun " . &makeprg<CR>

nnoremap <Leader>rt :execute 'botright terminal ++shell ++norestore ' . expand(&makeprg)<CR>
nnoremap <Leader>rn :execute 'Sh ' . expand(&makeprg)<CR>

" 垂直分割并打开光标下的文件
nnoremap <C-W>v :vsplit<CR>gf

nnoremap <M-f> gt
nnoremap <M-b> gT
nnoremap F gt
nnoremap B gT
nnoremap f gt
nnoremap b gT

" nnoremap <expr> <Esc>Z tabpagenr() == tabpagenr('$') ? ':tabm 0<CR>' : ':tabm +1<CR>'
" nnoremap <expr> <Esc>X tabpagenr() == 1 ? ':tabm $<CR>' : ':tabm -1<CR>'

let g:ycm_goto_buffer_command="split-or-existing-window"


" Experimental settings
set autoread

let g:vim_reader_epub_line_width=65

" Start interactive EasyAlign in visual mode (e.g. vipga)
xmap ga <Plug>(EasyAlign)
" Start interactive EasyAlign for a motion/text object (e.g. gaip)
nmap ga <Plug>(EasyAlign)

" Tagbar ocnfiguration for gotags
let g:tagbar_type_go = {
	\ 'ctagstype' : 'go',
	\ 'kinds'     : [
		\ 'p:package',
		\ 'i:imports:1',
		\ 'c:constants',
		\ 'v:variables',
		\ 't:types',
		\ 'n:interfaces',
		\ 'w:fields',
		\ 'e:embedded',
		\ 'm:methods',
		\ 'r:constructor',
		\ 'f:functions'
	\ ],
	\ 'sro' : '.',
	\ 'kind2scope' : {
		\ 't' : 'ctype',
		\ 'n' : 'ntype'
	\ },
	\ 'scope2kind' : {
		\ 'ctype' : 't',
		\ 'ntype' : 'n'
	\ },
	\ 'ctagsbin'  : 'gotags',
	\ 'ctagsargs' : '-sort -silent'
\ }

command! -bang -range -nargs=* -complete=file Grep AsyncRun -program=grep @<args>

tnoremap <Esc>W <C-W>.

vnoremap <silent> <Leader>y :w !xclip -selection clipboard<CR><CR>
